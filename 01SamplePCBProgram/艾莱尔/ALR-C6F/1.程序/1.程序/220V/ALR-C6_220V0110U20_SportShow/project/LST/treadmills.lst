 512          //Ęąťů 100ms
 513          void treadmills_disp_loop(void)
 514          {
 515   1        static u8 cnt=0;
 516   1        switch(treadmills.display.mode)
 517   1        {
 518   2          case DISP_MODE_AUTO:
 519   2            cnt=0;
 520   2      
 521   2            treadmills.display.index=0;  //0--speed 1--distance 2--calorie 3--time 4--programe
 522   2            treadmills_display(treadmills.display.index);
 523   2            treadmills.display.mode=DISP_MODE_TO_AUTO;          
 524   2            break;
 525   2          case DISP_MODE_TO_AUTO:
 526   2            cnt++;        
 527   2            if(cnt>50)//50*100ms=5s
 528   2            {
 529   3              cnt=0;
 530   3      
 531   3                if(treadmills.status==STATUS_POWERON||treadmills.status==STATUS_WAIT
 532   3                  ||treadmills.status==STATUS_RUNNING||treadmills.status==STATUS_STOP
 533   3                  ||treadmills.status==STATUS_STOP_WAIT){
 534   4                  treadmills.display.index++;
 535   4                  if(treadmills.display.index>=4){treadmills.display.index=0;}
 536   4                  treadmills_display(treadmills.display.index);
 537   4                }
 538   3            }
 539   2            break;
 540   2          case DISP_MODE_SINGLE:
 541   2            treadmills.display.index=0;
 542   2            treadmills_display(treadmills.display.index);
 543   2            treadmills.display.mode=DISP_MODE_TO_AUTO;  
 544   2            break;
 545   2          default:
 546   2            break;
 547   2        }
 548   1      }
