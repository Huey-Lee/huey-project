 551          void communication_checkout(void)
 552          {
 553   1        static u8 timeout=0;
 554   1        static u8 sm=0;
 555   1        static u8 error_cnt=0;
 556   1        switch(sm)
 557   1        {
 558   2          case 0:
 559   2            treadmills.ack=0;
 560   2            uart1_frame_tx(CMD_ACK,treadmills.ack);
 561   2            timeout=0;
 562   2            sm=1;
 563   2            break;
 564   2          case 1:
 565   2            timeout++;
 566   2            if(treadmills.ack==0)
 567   2            {
 568   3              uart1_frame_tx(CMD_ACK,treadmills.ack);
 569   3              if(timeout>1)
 570   3              {
 571   4                timeout=0;
 572   4                error_cnt++;
 573   4                if(error_cnt>10)
 574   4                {
 575   5                  treadmills.error_code=ERROR_06;
 576   5                  treadmills.status=STATUS_ERROR;
 577   5                  sm=2;
 578   5                  beep_set(1,ERROR_ON_TICKS,ERROR_OFF_TICKS);
 579   5                }
 580   4                else{sm=0;}
 581   4              }
 582   3            }
 583   2            else
 584   2            {
 585   3              error_cnt=0;
 586   3              sm=0;
 587   3            }
 588   2            break;
 589   2          case 2:
 590   2            break;
 591   2          default:
 592   2            break;
 593   2        }
 594   1      }
