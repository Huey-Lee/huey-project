  37          void MODIFY_HIRC_166(void)
  38          {
  39   1        unsigned char data hircmap0,hircmap1;
  40   1        unsigned int trimvalue16bit;
  41   1        /* Check if power on reset, modify HIRC */
  42   1        if (PCON&SET_BIT4)
  43   1        {
  44   2          CKDIV = 0x00;
  45   2          set_IAPEN;
  46   2          IAPAL = 0x30;
  47   2          IAPAH = 0x00;
  48   2          IAPCN = READ_UID;
  49   2          set_IAPGO;
  50   2          hircmap0 = IAPFD;
  51   2          IAPAL = 0x31;
  52   2          IAPAH = 0x00;
  53   2          set_IAPGO;
C51 COMPILER V9.60.0.0   MAIN                                                              08/07/2025 09:12:48 PAGE 2   

  54   2          hircmap1 = IAPFD;
  55   2          clr_IAPEN;
  56   2          trimvalue16bit = ((hircmap0<<1)+(hircmap1&0x01));
  57   2          trimvalue16bit = trimvalue16bit - 15;
  58   2          hircmap1 = trimvalue16bit&0x01;
  59   2          hircmap0 = trimvalue16bit>>1;
  60   2          TA=0XAA;
  61   2          TA=0X55;
  62   2          RCTRIM0 = hircmap0;
  63   2          TA=0XAA;
  64   2          TA=0X55;
  65   2          RCTRIM1 = hircmap1;
  66   2      
  67   2      
  68   2          //CKDIV = 0x50;         //HIRC devider 160
  69   2          //set_CLOEN;            //Check HIRC out wavefrom to confirm the HIRC modified
  70   2          /* Clear power on flag */
  71   2          PCON &= CLR_BIT4;
  72   2        }
  73   1      }
