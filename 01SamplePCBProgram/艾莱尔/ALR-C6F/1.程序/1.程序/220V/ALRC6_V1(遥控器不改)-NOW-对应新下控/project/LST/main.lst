  38          void MODIFY_HIRC_166(void)
  39          {
  40   1        unsigned char data hircmap0,hircmap1;
  41   1        unsigned int trimvalue16bit;
  42   1        /* Check if power on reset, modify HIRC */
  43   1        if (PCON&SET_BIT4)
  44   1        {
  45   2          CKDIV = 0x00;
  46   2          set_IAPEN;
  47   2          IAPAL = 0x30;
  48   2          IAPAH = 0x00;
  49   2          IAPCN = READ_UID;
  50   2          set_IAPGO;
  51   2          hircmap0 = IAPFD;
  52   2          IAPAL = 0x31;
  53   2          IAPAH = 0x00;
C51 COMPILER V9.60.0.0   MAIN                                                              07/25/2025 08:46:23 PAGE 2   

  54   2          set_IAPGO;
  55   2          hircmap1 = IAPFD;
  56   2          clr_IAPEN;
  57   2          trimvalue16bit = ((hircmap0<<1)+(hircmap1&0x01));
  58   2          trimvalue16bit = trimvalue16bit - 15;
  59   2          hircmap1 = trimvalue16bit&0x01;
  60   2          hircmap0 = trimvalue16bit>>1;
  61   2          TA=0XAA;
  62   2          TA=0X55;
  63   2          RCTRIM0 = hircmap0;
  64   2          TA=0XAA;
  65   2          TA=0X55;
  66   2          RCTRIM1 = hircmap1;
  67   2      
  68   2      
  69   2          //CKDIV = 0x50;         //HIRC devider 160
  70   2          //set_CLOEN;            //Check HIRC out wavefrom to confirm the HIRC modified
  71   2          /* Clear power on flag */
  72   2          PCON &= CLR_BIT4;
  73   2        }
  74   1      }
