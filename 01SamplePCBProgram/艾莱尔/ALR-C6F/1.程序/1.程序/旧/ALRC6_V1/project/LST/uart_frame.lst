  76          void uart1_frame_loop(void)  //ДгНгЪеЖгСажаЛёШЁ UART Ъ§Он
  77          {
  78   1         static u8 sm=0,len=0;
  79   1         static u8 *ptr;
  80   1         u8 dat;
  81   1         u8 ret;
  82   1         //ET0 = 0; //дЪаэжаЖЯ
  83   1         ret=Denter_queue(&UART1_rx_queue,&dat);
  84   1         //ET0 = 1; //дЪаэжаЖЯ
  85   1         if(ret)    //ret=1 ЖгСажагаЪ§ОнЃЌЪ§ОнГіЖгСаЃЌМДЗЂЫЭЪ§Он
  86   1         {
  87   2           if(dat==uart_frame.sof){sm=1;treadmills.ack=1;return;}
  88   2           switch(sm)
  89   2           {
  90   3           case 1:
  91   3             uart_frame.cmd=dat;
  92   3             sm=2;
  93   3             break;
  94   3           case 2:
  95   3             uart_frame.len=dat;
  96   3             if(uart_frame.len>2){sm=0;return;}
  97   3             len=0;
  98   3             ptr=&uart_frame.buf[0];
  99   3             sm=3;
 100   3             break;
 101   3           case 3:
 102   3             ptr[len]=dat;
 103   3             len++;
 104   3             if(len>=(uart_frame.len+2)){sm=4;}
 105   3             break;
 106   3           case 4:
 107   3             if(dat==uart_frame.eof)
 108   3             {
 109   4               ptr=&uart_frame.cmd;
 110   4               dat=0;
 111   4               for(len=0;len<(uart_frame.len+2);len++)
 112   4               {
C51 COMPILER V9.60.0.0   UART_FRAME                                                        07/25/2025 09:34:18 PAGE 3   

 113   5                dat^=ptr[len];
 114   5               }
 115   4               if(dat==ptr[len]){UART1_cmd_proc();}
 116   4             }
 117   3            sm=0;
 118   3             break;
 119   3           default:
 120   3             break;
 121   3           }
 122   2         }
 123   1      }
