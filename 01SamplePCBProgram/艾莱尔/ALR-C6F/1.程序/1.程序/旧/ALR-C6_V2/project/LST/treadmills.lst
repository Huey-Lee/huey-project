 505          //ЪБЛљ 100ms
 506          void treadmills_disp_loop(void)
 507          {
 508   1        static u8 cnt=0;
 509   1        switch(treadmills.display.mode)
 510   1        {
 511   2          case DISP_MODE_AUTO:
 512   2            cnt=0;
 513   2      
 514   2            treadmills.display.index=0;  //0--speed 1--distance 2--calorie 3--time 4--programe
 515   2            treadmills_display(treadmills.display.index);
 516   2            treadmills.display.mode=DISP_MODE_TO_AUTO;          
 517   2            break;
 518   2          case DISP_MODE_TO_AUTO:
 519   2            cnt++;        
 520   2            if(cnt>50)//50*100ms=5s
 521   2            {
 522   3              cnt=0;
 523   3      
 524   3                if(treadmills.status==STATUS_POWERON||treadmills.status==STATUS_WAIT
 525   3                  ||treadmills.status==STATUS_RUNNING||treadmills.status==STATUS_STOP
 526   3                  ||treadmills.status==STATUS_STOP_WAIT){
 527   4                  treadmills.display.index++;
 528   4                  if(treadmills.display.index>=4){treadmills.display.index=0;}
 529   4                  treadmills_display(treadmills.display.index);
 530   4                }
 531   3            }
 532   2            break;
 533   2          case DISP_MODE_SINGLE:
 534   2            treadmills.display.index=0;
 535   2            treadmills_display(treadmills.display.index);
 536   2            treadmills.display.mode=DISP_MODE_TO_AUTO;  
 537   2            break;
 538   2          default:
 539   2            break;
 540   2        }
 541   1      }
