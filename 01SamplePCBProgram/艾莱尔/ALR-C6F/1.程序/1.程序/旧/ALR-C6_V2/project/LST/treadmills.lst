 557   2          case 1:
 558   2            timeout++;
 559   2            if(treadmills.ack==0)
 560   2            {
 561   3              uart1_frame_tx(CMD_ACK,treadmills.ack);
 562   3              if(timeout>1)
 563   3              {
 564   4                timeout=0;
