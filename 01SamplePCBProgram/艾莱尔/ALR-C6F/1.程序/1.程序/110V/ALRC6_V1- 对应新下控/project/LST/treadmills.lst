 487          //ЪБЛљ 100ms
 488          void treadmills_disp_loop(void)
 489          {
 490   1        static u8 cnt=0;
 491   1        switch(treadmills.display.mode)
 492   1        {
 493   2          case DISP_MODE_AUTO:
 494   2            cnt=0;
 495   2      
 496   2            treadmills.display.index=0;  //0--speed 1--distance 2--calorie 3--time 4--programe
 497   2            treadmills_display(treadmills.display.index);
 498   2            treadmills.display.mode=DISP_MODE_TO_AUTO;          
 499   2            break;
 500   2          case DISP_MODE_TO_AUTO:
 501   2            cnt++;        
 502   2            if(cnt>50)//50*100ms=5s
 503   2            {
 504   3              cnt=0;
 505   3      
 506   3                if(treadmills.status==STATUS_POWERON||treadmills.status==STATUS_WAIT
 507   3                  ||treadmills.status==STATUS_RUNNING||treadmills.status==STATUS_STOP
 508   3                  ||treadmills.status==STATUS_STOP_WAIT){
 509   4                  treadmills.display.index++;
 510   4                  if(treadmills.display.index>=4){treadmills.display.index=0;}
 511   4                  treadmills_display(treadmills.display.index);
 512   4                }
 513   3            }
 514   2            break;
 515   2          case DISP_MODE_SINGLE:
 516   2            treadmills.display.index=0;
 517   2            treadmills_display(treadmills.display.index);
 518   2            treadmills.display.mode=DISP_MODE_TO_AUTO;  
 519   2            break;
 520   2          default:
 521   2            break;
 522   2        }
 523   1      }
