 526          void communication_checkout(void)
 527          {
 528   1        static u8 timeout=0;
 529   1        static u8 sm=0;
 530   1        static u8 error_cnt=0;
 531   1        switch(sm)
 532   1        {
 533   2          case 0:
 534   2            treadmills.ack=0;
 535   2            uart1_frame_tx(CMD_ACK,treadmills.ack);
 536   2            timeout=0;
 537   2            sm=1;
 538   2            break;
 539   2          case 1:
 540   2            timeout++;
 541   2            if(treadmills.ack==0)
 542   2            {
 543   3              uart1_frame_tx(CMD_ACK,treadmills.ack);
 544   3              if(timeout>1)
 545   3              {
 546   4                timeout=0;
 547   4                error_cnt++;
 548   4                if(error_cnt>10)
C51 COMPILER V9.60.0.0   TREADMILLS                                                        07/25/2025 12:14:17 PAGE 10  

 549   4                {
 550   5                  treadmills.error_code=ERROR_06;
 551   5                  treadmills.status=STATUS_ERROR;
 552   5                  sm=2;
 553   5                  beep_set(1,ERROR_ON_TICKS,ERROR_OFF_TICKS);
 554   5                }
 555   4                else{sm=0;}
 556   4              }
 557   3            }
 558   2            else
 559   2            {
 560   3              error_cnt=0;
 561   3              sm=0;
 562   3            }
 563   2            break;
 564   2          case 2:
 565   2            break;
 566   2          default:
 567   2            break;
 568   2        }
 569   1      }
