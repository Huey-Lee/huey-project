 470   2          high=((u32)TIME_VAL/60)%100;
 471   2          low=(u32)TIME_VAL%60;
 472   2      
 473   2          if(TIME_VAL<600)
 474   2          {
 475   3            set_seg_two(high,low);
 476   3            set_bit_seg(0,SEG_ALL_OFF);//ЧПжЦЙиБеЯдЪО
 477   3          }
 478   2          else
 479   2          {
 480   3            set_seg_two(high,low);
 481   3          }
 482   2      
 483   2        }
 484   1      }
