   6          void pwm_init(void)
   7          {
   8   1          PWM1_P14_OUTPUT_ENABLE;
   9   1        
  10   1          PWM_IMDEPENDENT_MODE;
  11   1      /**********************************************************************
  12   1        PWM frequency = Fpwm/((PWMPH,PWMPL) + 1) <Fpwm = Fsys/PWM_CLOCK_DIV> 
  13   1                      = (16MHz/8)/(999 + 1)
  14   1                      = 2KHz
  15   1      ***********************************************************************/
  16   1          PWM_CLOCK_DIV_8;
  17   1          PWMPH = (740>>8);//600 //old:900
  18   1          PWMPL = (740);   //old:900
  19   1      
  20   1          PWM1H = (0>>8);
  21   1          PWM1L = 0;
  22   1          
  23   1      /* PWM output inversly enable */
  24   1          PWM1_OUTPUT_NORMAL;
  25   1      
  26   1      /*-------- PWM start run--------------*/ 
  27   1          set_LOAD;
  28   1          set_PWMRUN;
  29   1      }
  30          
  31          
  32          void PWM1DutyCycle(UINT16 pwm)
  33          {
  34   1        PWM1H = (pwm>>8);
  35   1        PWM1L = pwm;
  36   1        set_LOAD;// 陋潼鷺퍅뵨欖왕궐鑒앴
  37   1      }
