   9          #include "7_segment.h"
  10          
  11          /**
  12           * 硬件接口连接定义
  13           */
  14          #define TM_CS   (P13)
  15          #define TM_DIO  (P11)
  16          #define TM_CLK  (P12)
  17          
  18          /**
  19           * CS:低电平有效
  20           * CLK:上升沿有效，即：低电平时候需要稳定数据。
  21           */
  22          static void wt_byte(u8 dat)
  23          {
  24   1        u8 i;
  25   1        for(i=0;i<8;i++)
  26   1        {
  27   2          TM_CLK=0;
  28   2          TM_DIO = (dat &0x01);
  29   2          dat>>=1;
  30   2          TM_CLK=1;
  31   2        }
  32   1        TM_CLK=0;
  33   1      }
  34          
  35          
  36          void aip1628_write_byte(u8 addr,u8 dat)
  37          {
  38   1        TM_CS=0;
  39   1        wt_byte(ADDR_CMD|addr);
  40   1        wt_byte(dat);
  41   1      //  wt_byte((u8)(dat>>8));
  42   1        TM_CS=1;
  43   1      }
  44          
  45          
  46          void aip1628_write_nbytes(u8 addr,u8 *p, u8 len)
  47          {
  48   1        TM_CS=0;
  49   1        wt_byte(ADDR_CMD|addr);
  50   1        for(;len>0;len--)
  51   1        {
  52   2          wt_byte(*p);
  53   2          p++;
