 366          void uart0_frame_loop(void)  //ДгНгЪеЖгСажаЛёШЁ UART Ъ§Он
 367          {
 368   1         static u8 sm=0,len=0;    // ОВЬЌБфСПгУгкБЃДцзДЬЌКЭГЄЖШаХЯЂ
 369   1         static u8 *ptr;          // жИЯђЪ§ОнЛКГхЧјЕФжИеы
