 406          void UART0_cmd_proc(void)
 407          {   
 408   1          uint8_t speed = treadmills.param.speed / 10;// ЬсШЁГЃгУБфСП
 409   1          uint16_t seconds = treadmills.param.second;
 410   1          uint32_t distance = (uint32_t)treadmills.param.distance;
 411   1          uint16_t calorie = treadmills.param.calorie / 100;
 412   1          switch (uart0_frame.cmd)
 413   1          {
 414   2          case 0x50: // ЛёШЁЩшБИаХЯЂ
 415   2              switch (uart0_frame.subcmd)
