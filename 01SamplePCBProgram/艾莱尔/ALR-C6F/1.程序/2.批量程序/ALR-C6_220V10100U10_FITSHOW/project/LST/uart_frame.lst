 372   1      
 373   1         rett=Denter_queue(&UART0_rx_queue,&datt);   // ДгUART0_rx_queueЖгСажаЖСШЁЪ§Он
 374   1         if(rett)    // ШчЙћГЩЙІЖСШЁЕНЪ§Он
 375   1         {
 376   2           switch(sm)
 377   2           {
 378   3           case 1:   // зДЬЌ1ЃЌНгЪеУќСюзжНк
 379   3             uart0_frame.cmd=datt;   // БЃДцУќСюзжНк    
 380   3             sm=2;
 381   3             break;
 382   3           case 2:   // зДЬЌ2ЃЌНгЪезгУќСюзжНк
 383   3             uart0_frame.subcmd=datt;   // БЃДцзгУќСюзжНк
 384   3             len=0;    // ЧхСуЪ§ОнГЄЖШМЦЪ§Цї
 385   3             ptr=&uart0_frame.buf[0];    // жИЯђЪ§ОнЛКГхЧјЕФЦ№ЪМЮЛжУ
 386   3             sm=3;
 387   3             break;
 388   3           case 3:   // зДЬЌ3ЃЌНгЪеЪ§ОнзжНк
 389   3             if(datt==0x03)
 390   3             {
 391   4               UART0_cmd_proc();
 392   4               sm=0;
 393   4             } 
 394   3             ptr[len]=datt;       
 395   3             len++;
 396   3             break;
 397   3           default:
 398   3             if(datt==0X02){sm=1;}   // ШчЙћЖСШЁЕНЕФЪ§ОнЪЧЦ№ЪМзжНк,ЧаЛЛЕНзДЬЌ1
 399   3             break;
