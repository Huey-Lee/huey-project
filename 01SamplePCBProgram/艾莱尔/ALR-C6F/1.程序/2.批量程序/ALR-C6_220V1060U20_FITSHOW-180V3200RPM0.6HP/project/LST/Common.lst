  13          #include "N76E003.h"
  14          #include "Common.h"
  15          #include "Delay.h"
  16          #include "SFR_Macro.h"
  17          #include "Function_define.h"
  18          
  19          #define FOSC_166000
  20          #define SW_Reset_EN
  21          
  22          
  23          //----------------------------------------------------------------------------------
  24          // UART0 baud rate initial setting 
  25          //----------------------------------------------------------------------------------
  26          void InitialUART0_Timer1(UINT32 u32Baudrate)    //T1M = 1, SMOD = 1
  27          {
  28   1          P06_Quasi_Mode;   //Setting UART pin as Quasi mode for transmit
  29   1          P07_Quasi_Mode;   //Setting UART pin as Quasi mode for transmit
  30   1        
  31   1          SCON = 0x50;      //UART0 Mode1,REN=1,TI=1
  32   1          TMOD |= 0x20;     //Timer1 Mode1
  33   1          
  34   1          set_SMOD;         //UART0 Double Rate Enable
  35   1          set_T1M;
  36   1          clr_BRCK;         //Serial port 0 baud rate clock source = Timer1
  37   1       
  38   1      #ifdef FOSC_160000
                  TH1 = 256 - (1000000/u32Baudrate+1);               /*16 MHz */
              #endif      
  41   1      #ifdef FOSC_166000
  42   1          TH1 = 256 - (1037500/u32Baudrate);                 /*16.6 MHz */
  43   1      #endif
  44   1          set_TR1;
  45   1          set_TI;           //For printf function must setting TI = 1
  46   1      }
C51 COMPILER V9.60.0.0   COMMON                                                            11/06/2025 09:07:50 PAGE 2   

  47          //---------------------------------------------------------------
  48          void InitialUART0_Timer3(UINT32 u32Baudrate) //use timer3 as Baudrate generator
  49          {
  50   1          P06_Quasi_Mode;   //Setting UART pin as Quasi mode for transmit
  51   1          P07_Quasi_Mode;   //Setting UART pin as Quasi mode for transmit 
  52   1        
  53   1          SCON = 0x50;     //UART0 Mode1,REN=1,TI=1
  54   1          set_SMOD;        //UART0 Double Rate Enable
  55   1          T3CON &= 0xF8;   //T3PS2=0,T3PS1=0,T3PS0=0(Prescale=1)
  56   1          set_BRCK;        //UART0 baud rate clock source = Timer3
  57   1      
  58   1      #ifdef FOSC_160000
                  RH3    = HIBYTE(65536 - (1000000/u32Baudrate)-1);     /*16 MHz */
                  RL3    = LOBYTE(65536 - (1000000/u32Baudrate)-1);     /*16 MHz */
              #endif
  62   1      #ifdef FOSC_166000
  63   1          RH3    = HIBYTE(65536 - (1037500/u32Baudrate));       /*16.6 MHz */
  64   1          RL3    = LOBYTE(65536 - (1037500/u32Baudrate));       /*16.6 MHz */
  65   1      #endif
  66   1          set_TR3;         //Trigger Timer3
  67   1          set_TI;          //For printf function must setting TI = 1
  68   1      }
  69          
  70          
  71          //----------------------------------------------------------------------------------
  72          // UART1 baud rate initial setting 
  73          //----------------------------------------------------------------------------------
  74          void InitialUART1_Timer3(UINT32 u32Baudrate) //use timer3 as Baudrate generator
  75          {
  76   1          P02_Quasi_Mode;   //Setting UART pin as Quasi mode for transmit
  77   1          P16_Quasi_Mode;   //Setting UART pin as Quasi mode for transmit
  78   1        
  79   1          SCON_1 = 0x50;    //UART1 Mode1,REN_1=1,TI_1=1
  80   1          T3CON = 0x08;     //T3PS2=0,T3PS1=0,T3PS0=0(Prescale=1), UART1 in MODE 1
  81   1          clr_BRCK;
  82   1        
  83   1      #ifdef FOSC_160000
                  RH3    = HIBYTE(65536 - (1000000/u32Baudrate)-1);     /*16 MHz */
                  RL3    = LOBYTE(65536 - (1000000/u32Baudrate)-1);     /*16 MHz */
              #endif
  87   1      #ifdef FOSC_166000
  88   1          RH3    = HIBYTE(65536 - (1037500/u32Baudrate));       /*16.6 MHz */
  89   1          RL3    = LOBYTE(65536 - (1037500/u32Baudrate));       /*16.6 MHz */
  90   1      #endif
  91   1          set_TR3;         //Trigger Timer3
  92   1      }
