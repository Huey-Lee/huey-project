 553          void communication_checkout(void)
 554          {
 555   1        static u8 timeout=0;
 556   1        static u8 sm=0;
 557   1        static u8 error_cnt=0;
 558   1        switch(sm)
 559   1        {
 560   2          case 0:
 561   2            treadmills.ack=0;
 562   2            uart1_frame_tx(CMD_ACK,treadmills.ack);
 563   2            timeout=0;
 564   2            sm=1;
 565   2            break;
 566   2          case 1:
 567   2            timeout++;
 568   2            if(treadmills.ack==0)
 569   2            {
 570   3              uart1_frame_tx(CMD_ACK,treadmills.ack);
 571   3              if(timeout>1)
 572   3              {
 573   4                timeout=0;
 574   4                error_cnt++;
 575   4                if(error_cnt>10)
 576   4                {
 577   5                  treadmills.error_code=ERROR_06;
 578   5                  treadmills.status=STATUS_ERROR;
 579   5                  sm=2;
 580   5                  beep_set(1,ERROR_ON_TICKS,ERROR_OFF_TICKS);
 581   5                }
 582   4                else{sm=0;}
 583   4              }
 584   3            }
 585   2            else
 586   2            {
 587   3              error_cnt=0;
 588   3              sm=0;
 589   3            }
 590   2            break;
 591   2          case 2:
 592   2            break;
 593   2          default:
 594   2            break;
 595   2        }
 596   1      }
