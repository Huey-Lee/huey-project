 514          //╩▒╗ї 100ms
 515          void treadmills_disp_loop(void)
 516          {
 517   1        static u8 cnt=0;
 518   1        switch(treadmills.display.mode)
 519   1        {
 520   2          case DISP_MODE_AUTO:
 521   2            cnt=0;
 522   2      
 523   2            treadmills.display.index=0;  //0--speed 1--distance 2--calorie 3--time 4--programe
 524   2            treadmills_display(treadmills.display.index);
 525   2            treadmills.display.mode=DISP_MODE_TO_AUTO;          
 526   2            break;
 527   2          case DISP_MODE_TO_AUTO:
 528   2            cnt++;        
 529   2            if(cnt>50)//50*100ms=5s
 530   2            {
 531   3              cnt=0;
 532   3      
 533   3                if(treadmills.status==STATUS_POWERON||treadmills.status==STATUS_WAIT
 534   3                  ||treadmills.status==STATUS_RUNNING||treadmills.status==STATUS_STOP
 535   3                  ||treadmills.status==STATUS_STOP_WAIT){
 536   4                  treadmills.display.index++;
 537   4                  if(treadmills.display.index>=4){treadmills.display.index=0;}
 538   4                  treadmills_display(treadmills.display.index);
 539   4                }
 540   3            }
 541   2            break;
 542   2          case DISP_MODE_SINGLE:
 543   2            treadmills.display.index=0;
 544   2            treadmills_display(treadmills.display.index);
 545   2            treadmills.display.mode=DISP_MODE_TO_AUTO;  
 546   2            break;
 547   2          default:
 548   2            break;
