 497   3                  case 0:
 498   3                      uart0_send_frame(0x53, 0x03, 0x01, sizeof(name), name, 0x54);
 499   3                      break;
 500   3                  case 1:
 501   3                      uart0_send_frame(0x53, 0x04, 0x01, sizeof(feature_setting_data), feature_setting_data, 0x5
             -4);
 502   3                      break;
 503   3                  case 2:
 504   3                      uart0_send_frame(0x53, 0x04, 0x02, sizeof(treadmill_status), treadmill_status, 0x54);
 505   3                      break;
 506   3                  case 3:
 507   3                      uart0_send_frame(0x53, 0x04, 0x03, sizeof(speed_range), speed_range, 0x54);
 508   3                      break;
 509   3                  case 4:
 510   3                      uart0_send_frame(0x53, 0x04, 0x0A, sizeof(device_type), device_type, 0x54);
 511   3                      bt_param_send_flag = 0;
 512   3                      bt_param_send_step = 0;
 513   3                      break;
 514   3                  default:
 515   3                      break;
 516   3              }
 517   2          }
 518   1      }
