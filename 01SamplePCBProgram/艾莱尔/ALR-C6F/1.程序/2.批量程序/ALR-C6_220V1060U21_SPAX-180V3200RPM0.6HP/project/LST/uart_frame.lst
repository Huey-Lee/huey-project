 526          
 527          void bt_panel_send_speed(void)
 528          {
 529   1          u8 speed_buf[2];
 530   1      
 531   1          speed_buf[0] = treadmills.param.speed & 0xFF;         // ЕЭзжНк
 532   1          speed_buf[1] = (treadmills.param.speed >> 8) & 0xFF;  // ИпзжНк
 533   1      
 534   1          bt_panel_send_cmd(0x05, 0x02, speed_buf); // 0x05: ЩшжУЫйЖШЃЌГЄЖШЮЊ2
 535   1      }
