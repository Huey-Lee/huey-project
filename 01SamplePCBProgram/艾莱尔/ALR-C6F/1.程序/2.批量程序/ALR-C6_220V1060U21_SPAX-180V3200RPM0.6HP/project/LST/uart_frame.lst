 573          void send_motion_data_by_status(void)
 574          {
 575   1          u8 status_code;
 576   1      
 577   1          switch (treadmills.status)
 578   1          {
 579   2            
 580   2              case STATUS_POWERON:
 581   2              case STATUS_WAIT:
 582   2              case STATUS_STOP_OVER:
 583   2              case STATUS_PAUSE:
 584   2                  status_code = 0x01;
 585   2                  break;
 586   2              case STATUS_RUN:
 587   2                  status_code = 0x0E;//0x0E
 588   2                  break;
 589   2              case STATUS_RUNNING:
 590   2                  status_code = 0x0D;
 591   2                  break;
 592   2              case STATUS_STOP:
 593   2                  status_code = 0x0F;
 594   2                  break;
 595   2              case STATUS_ERROR:
 596   2      //            status_code = 0x10;
 597   2                  break;
 598   2              case STATUS_REED_ERROR:
 599   2      //            status_code = 0x11;
 600   2                  break;
 601   2              default:
 602   2                  return; // ВЛЩЯБЈ
 603   2          }
 604   1      
 605   1          send_motion_data(status_code);
