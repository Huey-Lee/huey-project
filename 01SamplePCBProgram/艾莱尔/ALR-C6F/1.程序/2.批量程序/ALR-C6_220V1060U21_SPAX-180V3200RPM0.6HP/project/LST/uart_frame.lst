 260          void uart0_send_frame(u8 sof, u8 cmd, u8 subcmd, u8 len, u8 *buf, u8 end)
 261          {
 262   1          u8 tx_buf[6 + MAX_DATA_LEN]; // max buffer
 263   1          u8 temp[3 + MAX_DATA_LEN];   // for CRC
 264   1          u8 i;
 265   1      
 266   1          tx_buf[0] = sof;
 267   1          tx_buf[1] = cmd;
 268   1          tx_buf[2] = subcmd;
 269   1          tx_buf[3] = len;
 270   1      
 271   1          temp[0] = cmd;
 272   1          temp[1] = subcmd;
 273   1          temp[2] = len;
 274   1      
 275   1          // ШчЙћгаЪ§Он
 276   1          if (len > 0 && buf != NULL)
 277   1          {
 278   2              for (i = 0; i < len; i++)
 279   2              {
 280   3                  tx_buf[4 + i] = buf[i];
 281   3                  temp[3 + i] = buf[i];
 282   3              }
 283   2          }
 284   1      
 285   1          tx_buf[4 + len] = crc_cheack(temp, 3 + len); // fcs
 286   1          tx_buf[5 + len] = end;                       // end
 287   1      
 288   1          UART_Send_Buf(UART0, tx_buf, 6 + len);       // total length
 289   1      }
