 538          // ========== ЩЯБЈдЫЖЏЪ§Она­вщжЁ ==========
 539          void send_motion_data(u8 status_code)
 540          {
 541   1          u8 buf[18];
 542   1          u16 speed     = treadmills.param.speed;
 543   1          u32 distance  = treadmills.param.distance;
C51 COMPILER V9.60.0.0   UART_FRAME                                                        12/12/2025 10:14:07 PAGE 10  

 544   1          u16 calorie   = treadmills.param.calorie / 1000;
 545   1          u16 hour_cal  = 0;
 546   1          u8  min_cal   = 0;
 547   1          u16 seconds   = treadmills.param.second;
 548   1          u16 steps     = 0;
 549   1          u16 flags     = 0x0484;//Юоsteps
 550   1      
 551   1          buf[0]  = status_code;
 552   1          buf[1]  = flags & 0xFF;
 553   1          buf[2]  = (flags >> 8) & 0xFF;
 554   1          buf[3]  = speed & 0xFF;
 555   1          buf[4]  = (speed >> 8) & 0xFF;
 556   1          buf[5]  = distance & 0xFF;
 557   1          buf[6]  = (distance >> 8) & 0xFF;
 558   1          buf[7]  = (distance >> 16) & 0xFF;
 559   1          buf[8]  = calorie & 0xFF;
 560   1          buf[9]  = (calorie >> 8) & 0xFF;
 561   1          buf[10] = hour_cal & 0xFF;
 562   1          buf[11] = (hour_cal >> 8) & 0xFF;
 563   1          buf[12] = min_cal;
 564   1          buf[13] = seconds & 0xFF;
 565   1          buf[14] = (seconds >> 8) & 0xFF;
 566   1          buf[15] = steps & 0xFF;
 567   1          buf[16] = (steps >> 8) & 0xFF;
 568   1          buf[17] = 0x00;
 569   1      
 570   1          uart0_send_frame(0x57, 0x01, 0x00, sizeof(buf), buf, 0x58);
 571   1      }
