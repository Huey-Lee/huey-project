 249          unsigned char crc_cheack(unsigned char *pkt, unsigned char len)  
 250          {  
 251   1          unsigned char i = 0, calculatedCRC = pkt[0];  
 252   1          for(i = 1; i < len; i++)   
 253   1          {  
 254   2              calculatedCRC ^= pkt[i];  
 255   2          }  
 256   1          return calculatedCRC;  
 257   1      }
