".\objects\cw32l010_gpio.o"
".\objects\cw32l010_btim.o"
".\objects\cw32l010_adc.o"
".\objects\cw32l010_atim.o"
".\objects\cw32l010_flash.o"
".\objects\cw32l010_gtim.o"
".\objects\cw32l010_systick.o"
".\objects\cw32l010_uart.o"
".\objects\bdc_hal.o"
".\objects\bdc_comm.o"
".\objects\bdc_init.o"
".\objects\motor.o"
".\objects\motor_drive.o"
